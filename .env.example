# =====================================================
# Acampamento Santa Rita — variáveis de ambiente
# Copie para .env e preencha conforme necessário.
# =====================================================

# --------- Banco ---------
DATABASE_URL=postgresql://santarita:senha@localhost:5432/santarita

# --------- Auth (Better Auth) ---------
BETTER_AUTH_SECRET=troque-isto-em-producao
BETTER_AUTH_URL=http://localhost:3333

# --------- Asaas (Pagamentos) ---------
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# --------- Cloudflare R2 (Storage) ---------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=santarita-uploads
R2_PUBLIC_URL=

# --------- Email (Resend) ---------
RESEND_API_KEY=
EMAIL_FROM=contato@acampamentosantarita.com.br

# --------- Push (Web Push API) ---------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@acampamentosantarita.com.br

# --------- Lojinha do site ---------
SHOP_WHATSAPP_NUMBER=

# --------- URLs (CORS / links) ---------
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
APP_URL=http://localhost:3002
API_URL=http://localhost:3333

# --------- Frontends (consumido pelo Vite/Next no client) ---------
VITE_API_URL=http://localhost:3333
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_SHOP_WHATSAPP_NUMBER=
