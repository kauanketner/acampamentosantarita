{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "**/dist",
      "**/.next",
      "**/.turbo",
      "**/node_modules",
      "**/drizzle",
      "**/build",
      "**/.vite",
      "**/coverage",
      "**/routeTree.gen.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "noNonNullAssertion": "off", "useImportType": "warn" },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "off",
        "noMisleadingCharacterClass": "warn",
        "noArrayIndexKey": "warn"
      },
      "complexity": { "noUselessFragments": "warn" },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "noAutofocus": "off",
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off",
        "useSemanticElements": "off"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  }
}
